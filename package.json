{
    "name": "steamdeck-webdev-template",
    "version": "0.3.0",
    "private": true,
    "author": {
        "name": "Victor Vinci",
        "url": "https://github.com/victorvinci"
    },
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "prepare": "husky",
        "setup": "bash scripts/dev-setup.sh",
        "fe": "nx serve frontend",
        "be": "nx serve backend",
        "storybook": "nx storybook frontend",
        "lint": "nx run-many --target=lint",
        "lint:fix": "nx run-many --target=lint --fix",
        "lint:migrations": "bash scripts/lint-migrations.sh",
        "lint:md": "markdownlint-cli2",
        "build:fe": "nx run frontend:build",
        "build:be": "nx run backend:build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "nx run-many --target=typecheck",
        "test": "nx run-many --target=test",
        "test:fe": "nx test frontend",
        "test:be": "nx test backend",
        "test:types": "nx test types",
        "test:utils": "nx test utils",
        "test:storybook": "test-storybook --config-dir apps/frontend/.storybook --url http://127.0.0.1:6006",
        "e2e": "nx run-many --target=e2e --projects=frontend-e2e,backend-e2e",
        "e2e:fe": "nx e2e frontend-e2e",
        "e2e:be": "nx e2e backend-e2e",
        "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
        "check:affected": "npm run format:check && nx affected -t lint typecheck test",
        "preflight": "npm run check && npm run e2e && nx run frontend:build-storybook",
        "migrate": "tsx scripts/migrate.ts",
        "migrate:status": "tsx scripts/migrate.ts --status",
        "db:reset": "tsx scripts/db-reset.ts",
        "check-env": "tsx scripts/check-env.ts",
        "gen:openapi": "tsx --tsconfig tsconfig.base.json scripts/gen-openapi.ts",
        "gen:openapi:check": "npm run gen:openapi && git diff --exit-code apps/backend/openapi.json",
        "dev": "npm run setup && npm run check-env && nx run-many --target=serve --projects=frontend,backend --parallel",
        "build": "npm run check && nx run-many --target=build",
        "clean": "rm -rf dist .nx/cache apps/frontend/storybook-static coverage"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^9.8.0",
        "@nx/devkit": "22.6.5",
        "@nx/esbuild": "22.6.5",
        "@nx/eslint": "22.6.5",
        "@nx/eslint-plugin": "22.6.5",
        "@nx/jest": "22.6.5",
        "@nx/js": "22.6.5",
        "@nx/node": "^22.6.5",
        "@nx/playwright": "22.6.5",
        "@nx/react": "^22.6.5",
        "@nx/storybook": "^22.6.5",
        "@nx/vite": "^22.6.5",
        "@nx/vitest": "22.6.5",
        "@nx/web": "22.6.5",
        "@playwright/test": "^1.36.0",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/react-vite": "10.3.5",
        "@storybook/test-runner": "^0.24.3",
        "@swc-node/register": "~1.11.1",
        "@swc/cli": "~0.8.0",
        "@swc/core": "~1.15.5",
        "@swc/helpers": "~0.5.18",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "24.12.2",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/swagger-ui-express": "^4.1.8",
        "@vitejs/plugin-react": "^6.0.0",
        "@vitest/coverage-v8": "~4.1.0",
        "@vitest/ui": "~4.1.0",
        "ajv": "^8.0.0",
        "esbuild": "^0.28.0",
        "eslint": "^9.8.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-playwright": "^2.10.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "husky": "^9.1.7",
        "jest": "^30.0.2",
        "jest-environment-node": "^30.0.2",
        "jest-util": "^30.0.2",
        "jiti": "^2.6.1",
        "jsdom": "~29.0.2",
        "jsonc-eslint-parser": "^3.1.0",
        "lint-staged": "^16.4.0",
        "markdownlint-cli2": "^0.22.1",
        "nx": "22.6.5",
        "pino-pretty": "^13.1.3",
        "prettier": "~3.8.3",
        "storybook": "10.3.5",
        "ts-jest": "^29.4.0",
        "ts-node": "^10.9.2",
        "tslib": "^2.3.0",
        "tsx": "^4.21.0",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.40.0",
        "vite": "^8.0.0",
        "vite-plugin-dts": "~4.5.0",
        "vitest": "~4.1.0"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@tanstack/react-query": "^5.97.0",
        "@tanstack/react-query-devtools": "^5.97.0",
        "@tanstack/react-router": "^1.168.19",
        "@tanstack/router-plugin": "^1.167.20",
        "axios": "^1.15.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "mysql2": "^3.22.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    }
}
