# Enforce LF line endings everywhere so contributors on Windows
# don't accidentally commit CRLF into the repo.
* text=auto eol=lf

# Explicitly mark binary files so Git never tries to diff them.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Mark generated files so they collapse in PR diffs by default.
apps/frontend/src/routeTree.gen.ts linguist-generated=true
package-lock.json linguist-generated=true
