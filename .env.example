# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# App
NODE_ENV=development
PORT=3000
HOST=localhost

# MySQL — required, no defaults
DB_HOST=localhost
DB_PORT=3306
DB_NAME=steamdeck_dev
DB_USER=steamdeck
DB_PASSWORD=change-me-before-first-boot
# Separate MySQL root password (docker-compose dev DB only). Must differ from DB_PASSWORD
# so leaking the app credential does not grant root on the dev container.
DB_ROOT_PASSWORD=change-me-too-and-make-it-different
DB_CONNECTION_LIMIT=10

# CORS — exact origin of the frontend, no wildcards
FRONTEND_URL=http://localhost:4200

# Frontend
VITE_API_URL=http://localhost:3000

# Playwright (apps/frontend-e2e) — only needed if you run e2e against a non-default URL
# BASE_URL=http://localhost:4200
