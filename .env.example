# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# App
NODE_ENV=development
PORT=3000
HOST=localhost

# MySQL — required, no defaults
DB_HOST=localhost
DB_PORT=3306
DB_NAME=steamdeck_dev
DB_USER=steamdeck
DB_PASSWORD=change-me-before-first-boot
DB_CONNECTION_LIMIT=10

# CORS — exact origin of the frontend, no wildcards
FRONTEND_URL=http://localhost:4200

# Frontend
VITE_API_URL=http://localhost:3000
